// version number - do not translate

// TP2 entries - starting at 1
@1 = ~Restored Rhynn Lanthorn mod do BG II, BG II EE i EET~
@2 = ~Mod przeznaczony dla Baldur's Gate II (wersja klasyczna lub Enhanced), Baldur's Gate Trilogy oraz Enhanced Edition Trilogy~
@3 = ~Masz juz zainstalowana wersje zadania Rhynn Lanthor z Oversight. Wybierz jedna z nich; jesli chcesz uzyc tej, odinstaluj komponent Oversight.~
@4 = ~Wersja klasyczna (przywrocenie wycietej zawartosci)~
@5 = ~Wersja rozszerzona (cztery dodatkowe lokacje)~